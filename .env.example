# Legal Document RAG System - Environment Variables Template
# ==============================================================================
# Copy this file as .env and fill with real values
# cp .env.example .env
# ==============================================================================

# ==============================================================================
# API KEYS (REQUIRED)
# ==============================================================================

# Gemini API (primary LLM provider)
# IMPORTANT: Never commit real API keys to git!
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# Backup keys for rotation (optional, for high load)
# GEMINI_API_KEY_1=your_backup_key_1_here
# GEMINI_API_KEY_2=your_backup_key_2_here

# ==============================================================================
# TELEGRAM BOT (REQUIRED)
# ==============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather_here
TELEGRAM_ADMIN_USER_IDS=your_telegram_id_here
TELEGRAM_ADMIN_IDS=[your_telegram_id_here]

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ChromaDB
CHROMA_DB_PATH=./legal_rag_chroma_db
COLLECTION_NAME=documents
DEFAULT_COLLECTION_NAME=documents
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_USE_HTTP=true
CHROMA_SSL=false
CHROMA_TIMEOUT=30

# PostgreSQL (Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_rag_db
POSTGRES_USER=legal_rag_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_MIN_POOL_SIZE=5
POSTGRES_MAX_POOL_SIZE=20
POSTGRES_CONNECTION_TIMEOUT=30
POSTGRES_SSL_MODE=prefer
POSTGRES_APPLICATION_NAME=LegalRAG_Bot
POSTGRES_TIMEZONE=UTC

# Neo4j (Graph Database)
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ==============================================================================
# MICROSERVICES CONFIGURATION
# ==============================================================================
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
ENVIRONMENT=development
DEBUG=false
MONITORING_ENABLED=true
STARTUP_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60

# ==============================================================================
# AI MODELS CONFIGURATION
# ==============================================================================
LLM_PROVIDER=gemini
EXTRACTION_MODEL_NAME=gemini-1.5-flash
AGENT_MODEL_NAME=gemini-1.5-flash
SUMMARY_MODEL_NAME=gemini-1.5-flash
QA_MODEL_NAME=gemini-1.5-flash

# Embeddings
EMBEDDING_MODEL_PROVIDER=gemini
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_MODEL_NAME=text-embedding-004
EMBEDDING_DIMENSION=768

# ==============================================================================
# RAG SYSTEM CONFIGURATION
# ==============================================================================
USE_OPTIMAL_RAG=true
RAG_CONFIG_NAME=optimal
MAX_CHUNKS=7
SIMILARITY_THRESHOLD=0.65

# Caching
CACHE_STRATEGY=adaptive
CACHE_TTL=3600
SEMANTIC_THRESHOLD=0.75

# Hybrid Search (BM25 + Semantic)
SEMANTIC_WEIGHT=0.6
KEYWORD_WEIGHT=0.4

# ==============================================================================
# DOCUMENT PROCESSING
# ==============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./legal_rag_documents
RETRIEVER_K=5

# ==============================================================================
# PERFORMANCE SETTINGS
# ==============================================================================
DB_POOL_SIZE=5
CACHE_MAXSIZE=100
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
MAX_RETRY_ATTEMPTS=2
MAX_CONCURRENT_PROCESSING=3
DB_QUERY_TIMEOUT=30

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_DEBUG_LOGS=false

# ==============================================================================
# ADMIN PANEL
# ==============================================================================
ADMIN_PANEL_PASSWORD=your_secure_admin_password_here
ADMIN_JWT_SECRET=your_secure_jwt_secret_key_here
ADMIN_PASSWORD_SALT=your_secure_salt_here
ADMIN_PANEL_SESSION_TIMEOUT=28800
